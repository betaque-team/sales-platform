# Environment & secrets
.env
!.env.example
*.pem
*.key

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node
node_modules/
dist/

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.lock.info
*.tfplan
terraform.tfvars

# Backups & dumps
backups/
*.sql
*.dump

# Docker
*.log

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# =============================================================================
# Cloudflare — tunnel credentials & API tokens
# (rotate immediately if any of these ever appear in a diff)
# =============================================================================
**/cloudflared/credentials.json
**/cloudflared/*.json
**/cloudflared/cert.pem
**/cloudflare/creds/
*cloudflare*token*

# =============================================================================
# Oracle Cloud Infrastructure — API signing keys
# =============================================================================
**/.oci/
*oci_api_key*

# =============================================================================
# SSH private keys (public .pub files are OK; private halves never)
# =============================================================================
id_rsa
id_ed25519
id_ecdsa
**/sales-platform-ci
# (explicitly allow the .pub counterpart)
!*.pub

# =============================================================================
# F265 — Playwright E2E artifacts (local-only runs, never committed)
# =============================================================================
playwright-report/
test-results/
playwright/.cache/
