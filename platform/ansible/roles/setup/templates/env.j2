# =============================================================================
# Production environment — managed by Ansible
# Do not edit manually; update group_vars/production.yml + re-run setup
# =============================================================================

# ── Database ──
DATABASE_URL=postgresql+asyncpg://{{ postgres_user }}:{{ postgres_password }}@postgres:{{ postgres_port }}/{{ postgres_db }}
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB={{ postgres_db }}
POSTGRES_HOST=postgres
POSTGRES_PORT={{ postgres_port }}

# ── Redis ──
REDIS_URL=redis://redis:{{ redis_port }}/0

# ── Auth ──
JWT_SECRET={{ jwt_secret }}

# ── AI ──
ANTHROPIC_API_KEY={{ anthropic_api_key }}

# ── Scan ──
SCAN_MODE={{ scan_mode }}

# ── Backup ──
BACKUP_DIR=/app/backups
BACKUP_KEEP_LAST={{ backup_keep_last }}
