# =============================================================================
# Production Docker Compose — managed by Ansible
# Uses pre-built images, persistent volumes, proper resource limits
# =============================================================================
services:
  postgres:
    image: postgres:16-alpine
    restart: always
    environment:
      POSTGRES_USER: {{ postgres_user }}
      POSTGRES_PASSWORD: {{ postgres_password }}
      POSTGRES_DB: {{ postgres_db }}
    volumes:
      - postgres-data:/var/lib/postgresql/data
    ports:
      - "127.0.0.1:{{ postgres_port }}:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ postgres_user }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 1G

  redis:
    image: redis:7-alpine
    restart: always
    command: redis-server --maxmemory 256mb --maxmemory-policy allkeys-lru
    volumes:
      - redis-data:/data
    ports:
      - "127.0.0.1:{{ redis_port }}:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 512M

  backend:
    build:
      context: ./platform/backend
    image: platform-backend
    restart: always
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    env_file:
      - {{ app_shared }}/env/.env
    ports:
      - "127.0.0.1:8000:8000"
    volumes:
      - backups:/app/backups
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/v1/monitoring')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    deploy:
      resources:
        limits:
          memory: 1G

  celery-worker:
    image: platform-backend
    restart: always
    command: celery -A app.workers.celery_app worker -l info --concurrency=2
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    env_file:
      - {{ app_shared }}/env/.env
    volumes:
      - backups:/app/backups
    deploy:
      resources:
        limits:
          memory: 1G

  celery-beat:
    image: platform-backend
    restart: always
    command: celery -A app.workers.celery_app beat -l info
    depends_on:
      - celery-worker
    env_file:
      - {{ app_shared }}/env/.env

  frontend:
    build:
      context: ./platform/frontend
    image: platform-frontend
    restart: always
    depends_on:
      - backend
    ports:
      - "127.0.0.1:3000:80"
    deploy:
      resources:
        limits:
          memory: 128M

volumes:
  postgres-data:
  redis-data:
  backups:
