# =============================================================================
# Sales Data Platform — .gitignore
# =============================================================================

# ── Environment / Secrets ──
.env
.env.*
!.env.example

# ── Cloudflare credentials (NEVER commit) ──
infra/cloudflare/creds/*.json
infra/cloudflare/creds/*.pem

# ── Backups (local) ──
backups/

# ── Python ──
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.egg

# ── Node ──
node_modules/
dist/
.vite/

# ── Docker ──
.docker/

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Deploy metadata ──
.last-deploy.json

# ── Terraform ──
infra/terraform/.terraform/
infra/terraform/terraform.tfstate
infra/terraform/terraform.tfstate.backup
infra/terraform/*.tfvars
!infra/terraform/terraform.tfvars.example
infra/terraform/crash.log
infra/terraform/.terraform.tfstate.lock.info

# ── OCI keys ──
*.oci/

# ── Ansible ──
ansible/*.retry
ansible/host_vars/*
!ansible/host_vars/.gitkeep
dist-build/
