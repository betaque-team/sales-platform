# =============================================================================
# Sales Data Platform — Environment Variables
# Copy to .env and fill in production values:  cp .env.example .env
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@postgres:5432/jobplatform
DATABASE_URL_SYNC=postgresql://postgres:CHANGE_ME@postgres:5432/jobplatform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=jobplatform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Application ───────────────────────────────────────────────────────────────
APP_URL=https://sales.yourcompany.com
API_URL=https://sales.yourcompany.com/api
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHARS
JWT_EXPIRE_HOURS=24

# ── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Access control (optional — comma-separated emails, empty = allow all) ────
ALLOWED_EMAILS=

# ── AI features (optional) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Scanning ──────────────────────────────────────────────────────────────────
# aggressive = scan every 30min (initial setup)
# normal     = scan twice daily (production)
SCAN_MODE=normal
SCAN_INTERVAL_HOURS=6
CAREER_PAGE_INTERVAL_HOURS=4

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_DIR=/app/backups
BACKUP_KEEP_LAST=14

# ── Workers ───────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=2

# ── Cloudflare Tunnel (optional — set if using make tunnel-*) ────────────────
# TUNNEL_TOKEN=           # alternative to config.yml: one-token tunnel
# CF_TUNNEL_NAME=sales-platform
# CF_DOMAIN=sales.yourcompany.com
