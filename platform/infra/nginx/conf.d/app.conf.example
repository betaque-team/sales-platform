# =============================================================================
# Sales Platform — Nginx site config
# Replace YOUR_DOMAIN with your actual domain before deploying.
# For initial setup without SSL, use: make ssl-init DOMAIN=sales.example.com
# =============================================================================

upstream backend_api {
    server backend:8000;
    keepalive 16;
}

upstream frontend_app {
    server frontend:80;
}

# ── HTTP → HTTPS redirect ────────────────────────────────────────────────────
server {
    listen 80;
    server_name YOUR_DOMAIN;

    # Certbot challenge
    location /.well-known/acme-challenge/ {
        root /usr/share/nginx/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ── HTTPS server ──────────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    server_name YOUR_DOMAIN;

    # SSL certs (managed by certbot)
    ssl_certificate     /etc/letsencrypt/live/YOUR_DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/YOUR_DOMAIN/privkey.pem;

    # SSL hardening
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_session_tickets off;
    ssl_stapling on;
    ssl_stapling_verify on;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;

    # ── API ──
    location /api/ {
        limit_req zone=api burst=60 nodelay;

        proxy_pass         http://backend_api;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Connection        "";
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }

    # ── Login rate limit ──
    # F208: `burst=3` + `rate=5r/m` (http block) previously tripped
    # before FastAPI's own rate limiter, producing HTML 503 pages that
    # the SPA displayed as "Network error" — hiding the friendlier
    # FastAPI "Too many failed login attempts" JSON 429. Now
    # `burst=20 nodelay` against `rate=30r/m` so FastAPI always wins
    # the race; nginx is a backstop for actual DoS-level abuse. Paired
    # with `limit_req_status 429` (nginx.conf http block) and the
    # named `@ratelimit_json` error page so any residual rate-limit
    # hits return JSON with a `Retry-After` the SPA can interpret.
    location /api/v1/auth/login {
        limit_req zone=login burst=20 nodelay;
        error_page 429 503 = @ratelimit_json;

        proxy_pass         http://backend_api;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # F208: named location returns a JSON 429 body so the SPA's
    # `res.json().catch(...)` path gets structured data instead of
    # HTML, and the Retry-After header is set for clients that honor
    # it. Kept minimal — FastAPI's own 429 path carries a more useful
    # detail string; this branch only fires on the edge case where
    # nginx's threshold is reached BEFORE FastAPI's.
    location @ratelimit_json {
        add_header Content-Type "application/json" always;
        add_header Retry-After "60" always;
        return 429 '{"detail":"Too many requests. Please wait and try again."}';
    }

    # ── Frontend (SPA) ──
    location / {
        proxy_pass         http://frontend_app;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # ── Health (no auth) ──
    location = /health {
        proxy_pass http://backend_api/api/v1/monitoring;
        access_log off;
    }
}
